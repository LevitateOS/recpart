{
  "name": "recpart-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "start": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "lint": "bunx oxlint --config ../../../.oxlintrc.json src --deny-warnings",
    "lint:fix": "bunx oxlint --config ../../../.oxlintrc.json src --fix",
    "format": "bunx oxfmt --config ../../../.oxfmtrc.json --write src package.json tsconfig.json",
    "format:check": "bunx oxfmt --config ../../../.oxfmtrc.json --check src package.json tsconfig.json",
    "check": "bun run typecheck && bun run lint && bun run format:check"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.2"
  }
}
